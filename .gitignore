# ─────────────────────────────────────────────
# SECRETOS — NUNCA subir al repositorio
# ─────────────────────────────────────────────
**/.env
!**/.env.example

# ─────────────────────────────────────────────
# DATOS — archivos de entrada/salida
# ─────────────────────────────────────────────
pipelines/data/*

# ─────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────
pipelines/logs/
**/*.log

# ─────────────────────────────────────────────
# NGINX PROXY MANAGER — volúmenes locales
# ─────────────────────────────────────────────
proxy/data/
proxy/letsencrypt/

# ─────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ─────────────────────────────────────────────
# SISTEMAS OPERATIVOS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# IDEs
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
